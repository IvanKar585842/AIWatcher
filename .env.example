# =============================================================================
# WatchFlowing — production environment
# Copy to .env.local (dev) or set in Vercel Project Settings (prod).
# Never commit real secrets.
# =============================================================================

# Database (Supabase PostgreSQL — Prisma)
# Use Supavisor pooler (IPv4). Quote values when using ?pgbouncer=true
DIRECT_URL="postgresql://postgres.[PROJECT-REF]:[PASSWORD]@aws-0-[REGION].pooler.supabase.com:5432/postgres"
DATABASE_URL="postgresql://postgres.[PROJECT-REF]:[PASSWORD]@aws-0-[REGION].pooler.supabase.com:6543/postgres?pgbouncer=true"

# Clerk Authentication (use pk_live_ / sk_live_ in production)
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_...
CLERK_SECRET_KEY=sk_test_...
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL=/dashboard
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL=/dashboard

# App URL (must match production domain — used for Stripe redirects + emails)
NEXT_PUBLIC_APP_URL=https://watchflowing.com

# Admin bootstrap (comma-separated emails → role=ADMIN on login). Required in production.
ADMIN_EMAILS=you@yourdomain.com

# AI Provider (openai | claude | gemini)
AI_PROVIDER=gemini
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o-mini
# Optional chat models (defaults applied if unset)
# OPENAI_CHAT_MODEL=gpt-4o-mini
# OPENAI_CHAT_MODEL_FAST=gpt-4o-mini
ANTHROPIC_API_KEY=sk-ant-...
ANTHROPIC_MODEL=claude-sonnet-4-20250514
GEMINI_API_KEY=...
GEMINI_MODEL=gemini-2.0-flash

# Stripe (use live keys + live Price IDs for public launch)
# Dashboard: https://dashboard.stripe.com/apikeys
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PRO_PRICE_ID=price_...
STRIPE_BUSINESS_PRICE_ID=price_...

# Resend (verify domain before launch)
RESEND_API_KEY=re_...
RESEND_FROM_EMAIL=WatchFlowing <notifications@watchflowing.com>

# Telegram Bot (server-side only). Production webhook:
# https://watchflowing.com/api/telegram/webhook
TELEGRAM_BOT_TOKEN=
TELEGRAM_BOT_USERNAME=WatchFlowAlertsBot
TELEGRAM_WEBHOOK_SECRET=your-webhook-secret
# Optional dedicated HMAC for Telegram link codes (falls back to webhook/cron secret)
# TELEGRAM_LINK_SECRET=

# Cron (required for /api/cron/* — Vercel Cron sends Authorization: Bearer <CRON_SECRET>)
CRON_SECRET=generate-a-long-random-secret

# Rate limiting (strongly recommended in production — multi-instance safe)
UPSTASH_REDIS_REST_URL=https://...
UPSTASH_REDIS_REST_TOKEN=...

# Optional Chromium override for Vercel serverless
# CHROMIUM_PACK_URL=https://github.com/Sparticuz/chromium/releases/download/v149.0.0/chromium-v149.0.0-pack.x64.tar
