generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum Plan {
  FREE
  PRO
  BUSINESS
}

enum MonitorStatus {
  ACTIVE
  PAUSED
  ERROR
}

enum MonitoringMode {
  ENTIRE_PAGE
  VISUAL_CHANGES
  TEXT_CHANGES
  CSS_SELECTOR
  XPATH
  PRICE_DETECTION
  KEYWORD_DETECTION
  TABLE_DETECTION
  PRODUCT_AVAILABILITY
  JOB_LISTINGS
  DOCUMENTATION_CHANGES
  API_RESPONSE
  RSS_FEED
  HTML_DIFF
  SCREENSHOT_DIFF
  AI_SMART
}

enum NotificationMethod {
  TELEGRAM
  EMAIL
  BOTH
}

enum MonitoringInterval {
  FIVE_MIN
  FIFTEEN_MIN
  THIRTY_MIN
  ONE_HOUR
  SIX_HOURS
  TWELVE_HOURS
  TWENTY_FOUR_HOURS
}

enum AnalysisStatus {
  PENDING
  COMPLETED
  SKIPPED
  FAILED
}

enum ChangeCategory {
  PRICE
  CONTENT
  JOBS
  POLICY
  CONTACT_INFO
  PRODUCT
  DOCUMENTATION
  FEATURES
  OTHER
}

enum ChangeImportance {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

enum NotificationChannel {
  TELEGRAM
  EMAIL
  IN_APP
}

enum NotificationStatus {
  PENDING
  SENT
  FAILED
}

enum UserRole {
  USER
  ADMIN
}

enum ReportFrequency {
  WEEKLY
  MONTHLY
}

enum ReportType {
  BUSINESS
  DEVELOPER
  SEO
  COMPETITOR
}

model User {
  id                  String         @id @default(cuid())
  clerkId             String         @unique
  email               String         @unique
  name                String?
  imageUrl            String?
  role                UserRole       @default(USER)
  telegramChatId                 String?
  telegramUsername               String?
  telegramConnected              Boolean        @default(false)
  telegramConnectedAt            DateTime?
  telegramNotificationsEnabled   Boolean        @default(true)
  emailNotificationsEnabled      Boolean        @default(true)
  onboardingCompleted            Boolean        @default(false)
  username            String?        @unique
  statusPageEnabled   Boolean        @default(false)
  statusPageTitle     String?
  referralCode        String?        @unique
  referredBy          String?
  referralSignups     Int            @default(0)
  weeklyReportEnabled Boolean        @default(true)
  reportFrequency     ReportFrequency @default(WEEKLY)
  reportType          ReportType      @default(BUSINESS)
  createdAt           DateTime       @default(now())
  updatedAt           DateTime       @updatedAt
  subscription        Subscription?
  monitors            Monitor[]
  notifications       Notification[]
  chatConversations   ChatConversation[]
  weeklyReports       WeeklyReport[]

  @@index([clerkId])
  @@index([email])
  @@index([role])
  @@index([username])
  @@index([referralCode])
}

model Subscription {
  id                   String    @id @default(cuid())
  userId               String    @unique
  user                 User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  plan                 Plan      @default(FREE)
  stripeCustomerId     String?   @unique
  stripeSubscriptionId String?   @unique
  stripePriceId        String?
  status               String    @default("active")
  currentPeriodStart   DateTime?
  currentPeriodEnd     DateTime?
  cancelAtPeriodEnd    Boolean   @default(false)
  createdAt            DateTime  @default(now())
  updatedAt            DateTime  @updatedAt

  @@index([stripeCustomerId])
  @@index([stripeSubscriptionId])
}

model Monitor {
  id                 String             @id @default(cuid())
  userId             String
  user               User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  name               String
  url                String
  description        String?            @db.Text
  category           String?
  tags               String[]           @default([])
  aiPrompt           String?            @db.Text
  config             Json?
  mode               MonitoringMode     @default(ENTIRE_PAGE)
  selector           String?
  keywords           String[]           @default([])
  interval           MonitoringInterval @default(TWELVE_HOURS)
  notificationMethod NotificationMethod @default(EMAIL)
  status             MonitorStatus      @default(ACTIVE)
  respectRobots      Boolean            @default(true)
  lastCheckedAt      DateTime?
  lastChangedAt      DateTime?
  nextCheckAt        DateTime?
  errorMessage       String?
  errorCount         Int                @default(0)
  statusPageVisible  Boolean            @default(true)
  createdAt          DateTime           @default(now())
  updatedAt          DateTime           @updatedAt
  snapshots          Snapshot[]
  changes            Change[]

  @@index([userId])
  @@index([status])
  @@index([nextCheckAt])
  @@index([status, nextCheckAt])
  @@unique([userId, url])
}

model Snapshot {
  id           String   @id @default(cuid())
  monitorId    String
  monitor      Monitor  @relation(fields: [monitorId], references: [id], onDelete: Cascade)
  rawHtml      String   @db.Text
  cleanedHtml  String   @db.Text
  contentHash  String
  extractedText String? @db.Text
  metadata     Json?
  createdAt    DateTime @default(now())

  @@index([monitorId])
  @@index([contentHash])
  @@index([createdAt])
}

model Change {
  id            String           @id @default(cuid())
  monitorId     String
  monitor       Monitor          @relation(fields: [monitorId], references: [id], onDelete: Cascade)
  summary       String           @db.Text
  importance    ChangeImportance @default(MEDIUM)
  category      ChangeCategory   @default(CONTENT)
  oldValue      String?          @db.Text
  newValue      String?          @db.Text
  bulletPoints  String[]         @default([])
  emoji         String           @default("🔔")
  oldHtml       String?          @db.Text
  newHtml       String?          @db.Text
  diffHtml      String?          @db.Text
  aiRawResponse Json?
  analysisStatus AnalysisStatus  @default(PENDING)
  createdAt     DateTime         @default(now())
  notifications Notification[]

  @@index([monitorId])
  @@index([createdAt])
  @@index([monitorId, createdAt])
  @@index([category])
  @@index([importance])
  @@index([analysisStatus])
}

model Notification {
  id        String              @id @default(cuid())
  userId    String
  user      User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  changeId  String
  change    Change              @relation(fields: [changeId], references: [id], onDelete: Cascade)
  channel   NotificationChannel
  status    NotificationStatus  @default(PENDING)
  sentAt    DateTime?
  error     String?
  createdAt DateTime            @default(now())

  @@index([userId])
  @@index([changeId])
  @@index([status])
}

model MonitorQueue {
  id          String   @id @default(cuid())
  monitorId   String   @unique
  scheduledAt DateTime
  attempts    Int      @default(0)
  lockedAt    DateTime?
  lockedBy    String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([scheduledAt])
  @@index([lockedAt])
}

model AnalyticsEvent {
  id         String   @id @default(cuid())
  type       String
  userId     String?
  metadata   Json?
  durationMs Int?
  createdAt  DateTime @default(now())

  @@index([type, createdAt])
  @@index([userId])
}

model ProcessedStripeEvent {
  id        String   @id
  createdAt DateTime @default(now())
}

enum ChatMessageRole {
  USER
  ASSISTANT
  SYSTEM
}

model ChatConversation {
  id               String        @id @default(cuid())
  userId           String
  user             User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  title            String        @default("New conversation")
  summary          String?       @db.Text
  summaryUpdatedAt DateTime?
  totalTokens      Int           @default(0)
  totalCostUsd     Float         @default(0)
  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @updatedAt
  messages         ChatMessage[]

  @@index([userId])
  @@index([userId, updatedAt])
  @@index([createdAt])
}

model ChatMessage {
  id               String           @id @default(cuid())
  conversationId   String
  conversation     ChatConversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  role             ChatMessageRole
  content          String           @db.Text
  promptTokens     Int?
  completionTokens Int?
  totalTokens      Int?
  costUsd          Float?
  model            String?
  cached           Boolean          @default(false)
  createdAt        DateTime         @default(now())

  @@index([conversationId])
  @@index([conversationId, createdAt])
  @@index([createdAt])
  @@index([role, createdAt])
}

model ChatAnswerCache {
  id                 String   @id @default(cuid())
  normalizedQuestion String   @unique
  questionHash       String   @unique
  answer             String   @db.Text
  hitCount           Int      @default(0)
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  @@index([hitCount])
}

model WeeklyReport {
  id               String          @id @default(cuid())
  userId           String
  user             User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  periodStart      DateTime
  periodEnd        DateTime
  reportType       ReportType      @default(BUSINESS)
  frequency        ReportFrequency @default(WEEKLY)
  status           String          @default("READY")
  executiveSummary String          @db.Text
  payload          Json
  shareToken       String?         @unique
  shareEnabled     Boolean         @default(false)
  aiUsed           Boolean         @default(false)
  emailSentAt      DateTime?
  telegramSentAt   DateTime?
  createdAt        DateTime        @default(now())
  updatedAt        DateTime        @updatedAt

  @@unique([userId, periodStart, periodEnd, reportType])
  @@index([userId, createdAt])
  @@index([shareToken])
  @@index([periodEnd])
}
