{
  "framework": "nextjs",
  "buildCommand": "npm run build",
  "installCommand": "npm install",
  "headers": [
    {
      "source": "/(.*)\\.(js|css|woff2|svg|png|jpg|jpeg|webp|avif|ico)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=31536000, immutable"
        }
      ]
    },
    {
      "source": "/og-image.png",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=86400, stale-while-revalidate=604800"
        }
      ]
    }
  ],
  "crons": [
    {
      "path": "/api/cron/monitoring",
      "schedule": "0 6 * * *"
    },
    {
      "path": "/api/cron/chat-cleanup",
      "schedule": "0 3 * * *"
    },
    {
      "path": "/api/cron/weekly-reports",
      "schedule": "0 8 * * 1"
    }
  ],
  "functions": {
    "src/app/api/cron/monitoring/route.ts": {
      "maxDuration": 120,
      "memory": 1536
    },
    "src/app/api/cron/weekly-reports/route.ts": {
      "maxDuration": 120,
      "memory": 1024
    },
    "src/app/api/monitors/[id]/check/route.ts": {
      "maxDuration": 120,
      "memory": 1536
    }
  }
}
