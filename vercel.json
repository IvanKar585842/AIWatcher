{
  "framework": "nextjs",
  "buildCommand": "npm run build",
  "installCommand": "npm install",
  "crons": [
    {
      "path": "/api/cron/chat-cleanup",
      "schedule": "0 3 * * *"
    }
  ],
  "functions": {
    "src/app/api/cron/monitoring/route.ts": {
      "maxDuration": 60,
      "memory": 1536
    },
    "src/app/api/monitors/[id]/check/route.ts": {
      "maxDuration": 60,
      "memory": 1536
    }
  }
}
