{
  "framework": "nextjs",
  "buildCommand": "npm run build",
  "installCommand": "npm install",
  "crons": [
    {
      "path": "/api/cron/monitoring",
      "schedule": "*/5 * * * *"
    }
  ],
  "env": {
    "AWS_LAMBDA_JS_RUNTIME": "nodejs22.x"
  },
  "functions": {
    "src/app/api/cron/monitoring/route.ts": {
      "maxDuration": 60,
      "memory": 1024
    },
    "src/app/api/monitors/[id]/check/route.ts": {
      "maxDuration": 60,
      "memory": 1024
    }
  }
}
